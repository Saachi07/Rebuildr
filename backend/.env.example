# --- Supabase ------------------------------------------------------------
# Project Settings → API → Project URL
SUPABASE_URL=
# Project Settings → API → anon public key (safe to ship to clients)
SUPABASE_ANON_KEY=
# Project Settings → API → service_role key (server-only; bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=
# Project Settings → API → JWT Secret (used to verify access tokens locally)
SUPABASE_JWT_SECRET=

# --- AI (used by the image and PDF pipelines + recommendation signals) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Flask ---------------------------------------------------------------
FLASK_APP=run.py
FLASK_DEBUG=1
FLASK_SECRET_KEY=change-me
