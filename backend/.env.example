# Copy to .env and fill in. Never commit .env.

# --- Database -------------------------------------------------------------
# Supabase Postgres connection string (Project Settings → Database → URI).
# Leave DATABASE_URL unset to use the SQLite fallback at instance/rebuildr.db.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=

# --- Supabase (REST/Storage client; separate from the Postgres URL) -------
# Project URL — Project Settings → API → Project URL
SUPABASE_URL=
# anon or service_role key — Project Settings → API → Project API keys
SUPABASE_KEY=

# --- AI ------------------------------------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Flask ---------------------------------------------------------------
FLASK_APP=run.py
FLASK_DEBUG=1
FLASK_SECRET_KEY=change-me
