# --- Supabase ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# --- AI (used by the image and PDF pipelines + recommendation signals) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Flask ---------------------------------------------------------------

FLASK_APP=run.py
FLASK_DEBUG=1
FLASK_SECRET_KEY=change-me

# --- CORS ----------------------------------------------------------------
# Comma-separated browser origins allowed to call this API. Local Vite dev is
# the default; in production set this to your deployed frontend origin(s),
# e.g. https://your-user.github.io
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
