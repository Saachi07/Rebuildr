VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Temporary: set to 1 to let visitors try the product without signing up.
# Anyone without a session gets a real but anonymous Supabase user (each gets
# their own isolated data). Requires Anonymous Sign-Ins enabled in the Supabase
# dashboard (Authentication > Sign In / Providers). Leave unset to require login.
# VITE_DISABLE_AUTH=1
