VITE_API_BASE=https://rebuildr-backend.onrender.com
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Demo mode: set to 1 to let visitors try the product without a sign-up screen.
# Each device silently gets its own real email+password Supabase account (with
# isolated data) generated on first visit. Requires email confirmation to be
# OFF for the Supabase project, the generated addresses are not real inboxes.
# Leave unset to require real sign-in. The landing CTAs depend on this being on.
# VITE_DISABLE_AUTH=1
